# Pick ONE text-provider key below (DeepSeek, OpenCode Go, or GLM) — the proxy
# uses whichever is set. If more than one is set, priority is:
# OpenCode Go > GLM > DeepSeek.

# DeepSeek API Key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenCode API Key (https://opencode.ai)
OPENCODE_API_KEY=your_opencode_api_key_here

# GLM / Z.ai API Key (https://z.ai — GLM Coding Plan)
GLM_API_KEY=your_glm_api_key_here

# Google Gemini API Key (https://aistudio.google.com/apikey — free tier)
# Always required — used for image OCR regardless of which text provider you pick.
GEMINI_API_KEY=your_gemini_api_key_here
